  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "register test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "    pm.test(\"Token extracted and saved\", function() {",
                  "        pm.expect(jsonData.token).to.not.be.undefined;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@university.edu.vn\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Super Admin Test\",\n  \"systemRole\": \"ADMIN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/auth/register-test",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "auth",
                "register-test"
              ]
            }
          },
          "response": []
        },
