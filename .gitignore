# ==========================================
# MASTER .GITIGNORE FOR PTHTW SYSTEM (MONOREPO)
# ==========================================

# 1. HỆ ĐIỀU HÀNH (OS Files)
# ------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# 2. CÔNG CỤ LẬP TRÌNH (IDE & Editors)
# ------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.project
.classpath
.settings/

# 3. THÔNG TIN BẢO MẬT & MÔI TRƯỜNG (Secrets & Env)
# ------------------------------------------
# Cực kỳ quan trọng: Tuyệt đối không đẩy file chứa mật khẩu lên Git
.env
.env.*
!.env.example
!.env.production.example
*.pem
*.key
application-secret.yml

# 4. FRONTEND (ReactJS / Node.js)
# ------------------------------------------
# Áp dụng cho thư mục PTHTW_FrontEnd và bất kỳ đâu
node_modules/
dist/
build/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.parcel-cache/

# 5. BACKEND (Spring Boot / Java / Maven)
# ------------------------------------------
# Áp dụng cho thư mục PTHTW_BackEnd và bất kỳ đâu
target/
*.class
*.jar
*.war
*.ear
*.nar
*.log

uploads/
attachments/

# 6. DỮ LIỆU CỦA DOCKER VÀ DATABASE LOCAL
# ------------------------------------------
mysql_data/
db_data/
pgdata/

# 7. TÀI LIỆU BÁO CÁO & NHẬT KÝ THỰC THI (Documentation & Logs)
# ------------------------------------------
# Bỏ qua toàn bộ các file Markdown (nhật ký AI, kịch bản test, báo cáo lỗi)
*.md
# Bỏ qua các file cấu hình Postman nội bộ (nếu có)
*postman_collection.json
*postman_environment.json

# ==========================================
# LƯU Ý CHO TEAM: CÁC FILE ĐƯỢC PHÉP COMMIT (NGOẠI LỆ)
# ==========================================
# Các file tài liệu gốc, cấu hình docker sẽ được giữ lại
!README.md